# ═══ EXCHANGE (required) ═══
WALLET_ADDRESS=0x...
PRIVATE_KEY=0x...

# ═══ TRADING ═══
SYMBOL=BTC/USDC:USDC
STRATEGY=simple_sma
LOOP_INTERVAL=60
LEVERAGE=1
DRY_RUN=true

# ═══ RISK ═══
RISK_PER_TRADE=0.02
MAX_POSITION_SIZE_USD=500
MAX_OPEN_POSITIONS=3
MAX_DAILY_LOSS=0.05
MAX_DRAWDOWN=0.15

# ═══ SERVER ═══
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# ═══ DATABASE ═══
DATABASE_PATH=data/trading.db
